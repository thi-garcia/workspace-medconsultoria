# ─── Banco de dados (MySQL) ───────────────────────────────
# Local (docker compose up -d) usa estes valores por padrão.
# Em produção (TineHost), o painel/servidor terá o próprio .env.
DATABASE_URL="mysql://medconsultoria:medconsultoria@localhost:3307/medconsultoria"

# ─── Sessão / Auth ────────────────────────────────────────
# Segredo para assinar o cookie de sessão. GERE UM ALEATÓRIO em produção.
# Ex.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="troque-este-valor-em-producao-32-bytes-min"

# ─── App ──────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="4319"
# Origem do front em dev (Vite). Em produção é o próprio domínio.
WEB_ORIGIN="http://localhost:4310"
# Pasta onde ficam os arquivos enviados (upload de documentos). Em produção (TineHost),
# aponte para uma pasta PERSISTENTE fora do diretório do deploy (que o rsync sobrescreve).
# UPLOADS_DIR="storage/uploads"

# ─── IA (OpenAI — opcional) ───────────────────────────────
# Preencha para ligar a IA (assistente de busca + geração de documentos).
# Sem a chave, o app funciona normalmente e as funções de IA ficam ocultas.
# OPENAI_API_KEY="sk-..."
# Interruptor global da IA (privacidade): "false" desliga a IA mesmo com chave. Ver docs/IA_PRIVACIDADE.md
# IA_ENABLED="true"

# ─── E-mail transacional (opcional) ───────────────────────
# Sem SMTP_HOST, o app roda em "modo dev": os convites/links de acesso são
# exibidos na tela (para copiar) em vez de enviados por e-mail.
# Preencha para enviar convites e redefinição de senha de verdade.
# SMTP_HOST="smtp.seudominio.com.br"
# SMTP_PORT="587"
# SMTP_USER="no-reply@medconsultoria.com.br"
# SMTP_PASS="..."
# SMTP_FROM="MedConsultoria <no-reply@medconsultoria.com.br>"

# ─── Seed inicial (1º usuário ROOT) ───────────────────────
SEED_ROOT_EMAIL="root@medconsultoria.com.br"
SEED_ROOT_PASSWORD="troque-esta-senha"
SEED_ROOT_NOME="Administrador"
# Conta ADMIN da equipe (criada junto do ROOT pelo mesmo seed, com a mesma senha).
# Ver packages/db/src/seed-config.ts → EQUIPE_REAL.
SEED_ADMIN_EMAIL="thais.garcia@medconsultoria.com.br"
SEED_ADMIN_NOME="Thaís Garcia"

# ─── Só para testes (não usar em produção) ────────────────
# Banco separado dos testes de integração (vitest). O E2E usa `pnpm test:e2e:isolado`.
# TEST_DATABASE_URL="mysql://medconsultoria:medconsultoria@localhost:3307/medconsultoria_test"
# Libera `pnpm db:demo` contra banco remoto (NUNCA vale em NODE_ENV=production).
# DEMO_SEED_CONFIRMO="1"
# Portas alternativas, usadas pelo runner de E2E isolado. Não defina em produção.
# WEB_PORT="4310"

# .env de PRODUÇÃO / HOMOLOGAÇÃO — modelo. Copie para `.env` NO SERVIDOR e preencha.
# NUNCA commite o arquivo preenchido. Este modelo não contém nenhum segredo.
#
# Onde fica: na raiz do Application Root do app Node (DirectAdmin / CloudLinux Node.js Selector).
# Para homologação, veja as diferenças em docs/HOMOLOGACAO.md.

# ─── Obrigatórias ─────────────────────────────────────────
# Sem QUALQUER uma destas o app não sobe (validação por Zod em apps/api/src/config.ts).

NODE_ENV="production"

# MySQL da TineHost. Usuário com permissão só neste banco (least privilege).
DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/BANCO"

# Assina o cookie de sessão. GERE UM NOVO, exclusivo deste ambiente:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Trocar este valor derruba todas as sessões ativas.
SESSION_SECRET="GERE_UM_ALEATORIO_DE_32_BYTES"

# Domínio público do app, com https. Precisa bater EXATAMENTE com o endereço usado no
# navegador — é o que libera o cookie e o CORS.
WEB_ORIGIN="https://workspace.medconsultoria.com.br"

# Pasta dos arquivos enviados. OBRIGATÓRIO apontar para FORA do diretório do deploy:
# o rsync sobrescreve o diretório a cada publicação e levaria os uploads junto.
UPLOADS_DIR="/home/USUARIO/uploads"

# ─── Primeiro acesso (usadas uma vez, pelo seed) ──────────
# Depois de entrar, troque a senha pela aplicação (Configurações) e remova SEED_ROOT_PASSWORD.
SEED_ROOT_EMAIL="root@medconsultoria.com.br"
SEED_ROOT_PASSWORD="DEFINA_UMA_SENHA_FORTE"
SEED_ROOT_NOME="Administrador"
SEED_ADMIN_EMAIL="thais.garcia@medconsultoria.com.br"
SEED_ADMIN_NOME="Thaís Garcia"

# ─── Opcionais ────────────────────────────────────────────
# Sob Passenger a porta é gerenciada pelo servidor — deixe comentado.
# API_PORT="4319"

# E-mail transacional. Sem SMTP_HOST/USER/PASS o app NÃO envia nada: registra no histórico e
# mostra os links na tela. É assim que se deixa HOMOLOGAÇÃO (nunca escreve para clientes reais).
# SMTP_HOST="smtp.medconsultoria.com.br"
# SMTP_PORT="587"
# SMTP_USER="no-reply@medconsultoria.com.br"
# SMTP_PASS=""
# SMTP_FROM="MedConsultoria <no-reply@medconsultoria.com.br>"

# IA (OpenAI). Sem a chave, os recursos de IA aparecem desativados — nada quebra.
# OPENAI_API_KEY=""
# Interruptor de privacidade: "false" desliga a IA mesmo com chave. Ver docs/IA_PRIVACIDADE.md
# IA_ENABLED="true"

# ─── NUNCA definir em produção ────────────────────────────
# TEST_DATABASE_URL, DEMO_SEED_CONFIRMO, WEB_PORT, DOUTOR_CLIENTE_EMAIL, DOUTOR_CLIENTE_SENHA
# são de teste/diagnóstico local. DEMO_SEED_CONFIRMO em especial existe para liberar o seed de
# dados FICTÍCIOS — e o próprio seed já se recusa a rodar com NODE_ENV=production.

{
  "name": "workspace-medconsultoria",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:deploy": "turbo run build && node scripts/bundle-deploy.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:isolado": "node scripts/e2e-isolado.mjs",
    "verificar:bootstrap": "node scripts/verificar-bootstrap.mjs",
    "db:generate": "pnpm --filter @app/db generate",
    "db:migrate": "pnpm --filter @app/db migrate",
    "db:seed": "pnpm --filter @app/db seed",
    "db:demo": "pnpm --filter @app/db demo",
    "db:studio": "pnpm --filter @app/db studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "9.17.0",
    "@playwright/test": "1.49.1",
    "@types/node": "^22.10.2",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.19.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
